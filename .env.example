# ===================================================================
# 人选天选论 - 环境变量配置模板
# ===================================================================
# 复制此文件为 .env 并填入实际值
# cp .env.example .env

# ===== 服务器配置 =====
PORT=3000
NODE_ENV=development
# NODE_ENV=production  # 生产环境取消注释

# ===== 数据库配置 =====
# 开发环境（SQLite）
DATABASE_URL="file:./dev.db"

# 生产环境（MySQL）- 取消注释并填入实际值
# DATABASE_URL="mysql://root:your_password@localhost:3306/rxtxl?connection_limit=10&pool_timeout=20"

# ===== JWT配置 =====
# 生产环境必须替换！生成方式：
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=30d

# ===== 阿里云短信服务配置 =====
# 需要在阿里云控制台开通短信服务并创建签名和模板
# 文档：https://help.aliyun.com/document_detail/101414.html
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_SMS_SIGN_NAME=人选天选论
ALIYUN_SMS_TEMPLATE_CODE=SMS_XXXXXXXX

# ===== 管理后台密码 =====
# 生产环境必须修改！
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password

# ===== CORS配置 =====
# 开发环境
CORS_ORIGIN=http://localhost:10086

# 生产环境 - 填入前端部署域名（多个用逗号分隔）
# CORS_ORIGIN=https://your-domain.com,https://m.your-domain.com
