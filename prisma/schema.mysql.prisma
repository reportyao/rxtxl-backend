// Prisma Schema for 人选天选论 - MySQL生产环境版本
// 使用方法：将此文件复制为 schema.prisma，然后运行 npx prisma db push

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
  // MySQL连接字符串格式：mysql://USER:PASSWORD@HOST:PORT/DATABASE
}

// 用户表
model User {
  id            String    @id @default(uuid()) @db.VarChar(36)
  phone         String    @unique @db.VarChar(20)
  nickname      String?   @db.VarChar(50)
  avatar        String?   @db.VarChar(500)
  pinHash       String?   @db.VarChar(128)
  pinSalt       String?   @db.VarChar(64)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  lastLoginIp   String?   @db.VarChar(45)
  ipRegion      String?   @db.VarChar(100)
  streakDays    Int       @default(0)
  lastCheckinAt DateTime?

  diaries       Diary[]
  checkins      Checkin[]

  @@index([phone])
  @@index([lastLoginAt])
  @@index([createdAt])
  @@map("users")
}

// 文章表
model Article {
  id          String    @id @default(uuid()) @db.VarChar(36)
  title       String    @db.VarChar(200)
  summary     String?   @db.VarChar(500)
  content     String    @db.LongText // 富文本HTML内容
  chapter     Int
  status      String    @default("draft") @db.VarChar(20)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  viewCount   Int       @default(0)
  quotes      String?   @db.Text // JSON数组，存储金句列表

  @@index([chapter])
  @@index([status])
  @@index([publishedAt])
  @@map("articles")
}

// 道痕日记表（存储加密后的密文）
model Diary {
  id             String   @id @default(uuid()) @db.VarChar(36)
  userId         String   @db.VarChar(36)
  encryptedData  String   @db.LongText // AES-256加密后的日记密文
  iv             String   @db.VarChar(64) // 加密使用的初始化向量
  mainStone      String?  @db.VarChar(200)
  mainStoneHash  String?  @db.VarChar(64)
  diaryDate      String   @db.VarChar(10) // YYYY-MM-DD
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, diaryDate])
  @@index([userId])
  @@index([diaryDate])
  @@map("diaries")
}

// 打卡记录表
model Checkin {
  id          String   @id @default(uuid()) @db.VarChar(36)
  userId      String   @db.VarChar(36)
  checkinDate String   @db.VarChar(10) // YYYY-MM-DD
  streakCount Int      @default(1)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, checkinDate])
  @@index([userId])
  @@map("checkins")
}

// 管理员表
model Admin {
  id        String   @id @default(uuid()) @db.VarChar(36)
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(128)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}
