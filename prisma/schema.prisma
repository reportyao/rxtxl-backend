generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid()) @db.VarChar(36)
  phone         String?   @unique @db.VarChar(20)
  username      String?   @unique @db.VarChar(50)
  passwordHash  String?   @db.VarChar(128)
  nickname      String?   @db.VarChar(50)
  avatar        String?   @db.VarChar(500)
  pinHash       String?   @db.VarChar(64)
  pinSalt       String?   @db.VarChar(64)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  lastCheckinAt DateTime?
  lastLoginIp   String?   @db.VarChar(50)
  ipRegion      String?   @db.VarChar(50)
  streakDays    Int       @default(0)
  diaries       Diary[]
  checkins      Checkin[]
  @@map("users")
}

model Article {
  id          String    @id @default(uuid()) @db.VarChar(36)
  title       String    @db.VarChar(200)
  summary     String?   @db.Text
  content     String    @db.LongText
  chapter     Int
  quotes      String?   @db.Text
  status      String    @default("draft") @db.VarChar(20)
  publishedAt DateTime?
  scheduledAt DateTime?
  viewCount   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  @@index([status])
  @@index([chapter])
  @@map("articles")
}

model Diary {
  id             String   @id @default(uuid()) @db.VarChar(36)
  userId         String   @db.VarChar(36)
  encryptedData  String   @db.LongText
  iv             String   @db.VarChar(100)
  mainStone      String?  @db.Text
  mainStoneHash  String?  @db.VarChar(64)
  diaryDate      String   @db.VarChar(10)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@index([userId, diaryDate])
  @@index([mainStoneHash])
  @@map("diaries")
}

model Checkin {
  id          String   @id @default(uuid()) @db.VarChar(36)
  userId      String   @db.VarChar(36)
  checkinDate String   @db.VarChar(10)
  streakCount Int      @default(1)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, checkinDate])
  @@map("checkins")
}

model Admin {
  id        String   @id @default(uuid()) @db.VarChar(36)
  username  String   @unique @db.VarChar(50)
  password  String   @db.VarChar(100)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@map("admins")
}
